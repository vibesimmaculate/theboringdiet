# ─────────────────────────────────────────────────────────────
# The Boring Diet — environment variables
# Only VITE_* variables are exposed to the browser.
# ─────────────────────────────────────────────────────────────

# Site
VITE_SITE_URL=

# Polar (server-only unless VITE_ prefixed)
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
POLAR_PRODUCT_ID=
POLAR_ORGANIZATION_SLUG=
POLAR_ENVIRONMENT=sandbox
# Purchase gate. When false, purchase CTAs render as
# "PAYMENT ACCESS IS BEING FINALIZED" and the embedded checkout does not open.
POLAR_APPROVED=false

# Client-safe. The published Polar checkout link is a compile-time constant in
# src/config/brand.ts. The org slug is exposed to the browser only for the
# customer-portal URL.
VITE_POLAR_ORGANIZATION_SLUG=

# Meta
VITE_META_PIXEL_ID=
META_CONVERSIONS_API_TOKEN=

# Analytics
VITE_GA_MEASUREMENT_ID=

# SEO / verification
INDEXNOW_KEY=
GOOGLE_SITE_VERIFICATION=
BING_SITE_VERIFICATION=

# Support & legal placeholders (server-safe, shown on legal pages)
SUPPORT_EMAIL=
LEGAL_BUSINESS_NAME=
LEGAL_BUSINESS_ADDRESS=
GOVERNING_LAW=
REFUND_POLICY_SUMMARY=
